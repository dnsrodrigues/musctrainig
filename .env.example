# Copie este arquivo para .env e preencha com suas credenciais reais
# NUNCA commite o arquivo .env — apenas este .env.example

# Supabase — obter em: https://supabase.com > Seu Projeto > Settings > API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Groq API (IA gratuita) — obter em: https://console.groq.com
# Nota: a chave vai no Supabase como secret GROQ_API_KEY (não no frontend)
# VITE_GROQ_API_KEY não é necessário — a chave fica segura na Edge Function
